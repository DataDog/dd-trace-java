        }
      }
    },

    "implementation_strategy": {
      "phase_1_core_tags": {
        "files": ["InferredProxySpan.java"],
        "changes": [
          "Add aws-httpapi support",
          "Add span.kind=server",
          "Fix http.url scheme",
          "Add http.route from resourcePath",
          "Update resource.name logic"
        ],
        "complexity": "LOW"
      },

      "phase_2_appsec": {
        "investigation_needed": "How to access child service-entry span from InferredProxySpan to copy AppSec tags",
        "options": [
          "Option 1: In finish() hook, access child spans and copy tags",
          "Option 2: Use InstrumentationGateway callback",
          "Option 3: Use TraceSegmentPostProcessor"
        ],
        "recommended": "Option 1 if child span API available, else Option 3",
        "complexity": "HIGH"
      },

      "phase_3_testing": {
        "files": ["InferredProxySpanTests.java", "InferredProxyPropagatorTests.java"],
        "test_scenarios": [
          "V1 (aws-apigateway) and V2 (aws-httpapi) span names",
          "span.kind=server on all proxy spans",
          "https:// scheme in http.url",
          "http.route from resourcePath with fallback",
          "resource.name preferring route over path",
          "AppSec tag propagation",
          "Backwards compatibility"
        ]
      }
    },

    "backwards_compatibility": {
      "v2_migration": "Span name changes from aws.apigateway to aws.httpapi when header changes - intentional per RFC",
      "resource_path_header": "Optional header - fallback to path if not present",
      "resource_name_change": "Bugfix per RFC - document in release notes",
      "http_url_scheme": "Bugfix - should not break existing functionality"
    },

    "risks": {
      "low": ["span.kind tag", "https:// scheme", "aws-httpapi support"],
      "medium": ["http.route change", "resource.name change"],
      "high": ["AppSec propagation - complex, needs careful implementation"]
    }
  },

