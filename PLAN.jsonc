            "headers_extracted": ["x-dd-proxy", "x-dd-proxy-request-time-ms", "x-dd-proxy-path", "x-dd-proxy-httpmethod", "x-dd-proxy-domain-name", "x-dd-proxy-stage"],
            "missing_header": "x-dd-proxy-resource-path",
