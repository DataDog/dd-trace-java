<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
  <Match>
    <Or>
      <Class name="~com.datadog.debugger.util.WeakIdentityHashMap.*" />
      <Package name="datadog.trace.bootstrap.instrumentation.decorator.http.utils" />
      <Package name="datadog.smoketest.appsec.springboot.controller" />
      <Package name="datadog.smoketest.appsec.springboot.service" />
      <!-- these are auto-generated -->
      <Package name="com.datadog.appsec.report.raw.contexts._definitions" />
      <Package name="com.datadog.appsec.report.raw.contexts.actor" />
      <Package name="com.datadog.appsec.report.raw.contexts.agent" />
      <Package name="com.datadog.appsec.report.raw.contexts.code_location" />
      <Package name="com.datadog.appsec.report.raw.contexts.host" />
      <Package name="com.datadog.appsec.report.raw.contexts.http" />
      <Package name="com.datadog.appsec.report.raw.contexts.library" />
      <Package name="com.datadog.appsec.report.raw.contexts.service" />
      <Package name="com.datadog.appsec.report.raw.contexts.service_entry_span" />
      <Package name="com.datadog.appsec.report.raw.contexts.span" />
      <Package name="com.datadog.appsec.report.raw.contexts.sqreen" />
      <Package name="com.datadog.appsec.report.raw.contexts.tags" />
      <Package name="com.datadog.appsec.report.raw.contexts.trace" />
      <Package name="com.datadog.appsec.report.raw.events" />
    </Or>
  </Match>
  <!-- UnreadFields detector: unread/unused/unwritten field noise. This detector cannot be
       disabled via omitVisitors (other enabled detectors depend on it), so its patterns are
       filtered here instead. Matches the project's long-standing intent to ignore these. -->
  <Match>
    <Bug pattern="URF_UNREAD_FIELD,URF_UNREAD_PUBLIC_OR_PROTECTED_FIELD,UUF_UNUSED_FIELD,UUF_UNUSED_PUBLIC_OR_PROTECTED_FIELD,UWF_UNWRITTEN_FIELD,UWF_UNWRITTEN_PUBLIC_OR_PROTECTED_FIELD,NP_UNWRITTEN_PUBLIC_OR_PROTECTED_FIELD,SS_SHOULD_BE_STATIC,ST_WRITE_TO_STATIC_FROM_INSTANCE_METHOD,SIC_INNER_SHOULD_BE_STATIC" />
  </Match>
</FindBugsFilter>
